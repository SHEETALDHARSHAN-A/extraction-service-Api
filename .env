# IDEP Local Environment Configuration
# Copy this file to .env and adjust values as needed

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=idep
DATABASE_URL=postgresql://postgres:postgres@db:5432/idep

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (S3-compatible)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=idep-documents
MINIO_USE_SSL=false

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=document-processing-task-queue

# Triton
INFERENCE_BACKEND=glm_service
GLM_OCR_SERVICE_URL=http://localhost:8002
TRITON_HOST=localhost
TRITON_GRPC_PORT=8001
TRITON_HTTP_PORT=8000

# Services
PREPROCESSING_HOST=localhost:50051
POSTPROCESSING_HOST=localhost:50052

# OCR Services (HTTP)
PADDLEOCR_SERVICE_URL=http://localhost:8001

# API Gateway & Security
API_PORT=8000
IDEP_API_KEYS=tp-proj-dev-key-123:admin,tp-test-sandbox-456:viewer
