# IDEP Local Environment Configuration (Non-Docker)
# This .env is configured for running ALL services locally without Docker.

# ═══════════════════════════════════════════
# Database (SQLite for local development)
# ═══════════════════════════════════════════
DATABASE_DRIVER=sqlite
DATABASE_URL=idep_local.db

# ═══════════════════════════════════════════
# Storage Backend
# ═══════════════════════════════════════════
# "local" = local filesystem (no MinIO needed)
# "minio" = requires MinIO server running
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=C:\Users\MONISH RAJ T\OneDrive\Desktop\IDLE\.local\data\storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=idep-documents
MINIO_USE_SSL=false

# ═══════════════════════════════════════════
# Redis Cache (optional — graceful fallback)
# ═══════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════
# Temporal Workflow Engine
# ═══════════════════════════════════════════
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=document-processing-task-queue

# ═══════════════════════════════════════════
# Inference Backend
# ═══════════════════════════════════════════
# "glm_service" = direct HTTP to GLM-OCR FastAPI (no Triton needed)
# "triton"     = requires Triton Inference Server
INFERENCE_BACKEND=glm_service
GLM_OCR_SERVICE_URL=http://localhost:8002

# ═══════════════════════════════════════════
# Microservices (local ports)
# ═══════════════════════════════════════════
PREPROCESSING_HOST=localhost:50051
POSTPROCESSING_HOST=localhost:50052

# ═══════════════════════════════════════════
# PaddleOCR (optional for layout detection)
# ═══════════════════════════════════════════
PADDLEOCR_SERVICE_URL=http://localhost:8001

# ═══════════════════════════════════════════
# GLM-OCR Service
# ═══════════════════════════════════════════
GLM_MODEL_PATH=zai-org/GLM-OCR
GLM_PRECISION_MODE=high
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8002
REQUEST_TIMEOUT_SECONDS=180
LOW_VRAM_MAX_TOKENS=2048
LOW_VRAM_MAX_IMAGE_EDGE=1152
LOW_VRAM_RETRY_MAX_TOKENS=1024
LOW_VRAM_RETRY_IMAGE_EDGE=896
CHUNK_LARGE_PAGES=true
CHUNK_TRIGGER_MAX_EDGE=1400
CHUNK_SEGMENT_COUNT=3
CHUNK_OVERLAP_PX=120
CHUNK_SEGMENT_MAX_TOKENS=1024

# ═══════════════════════════════════════════
# API Gateway
# ═══════════════════════════════════════════
API_PORT=8000
IDEP_API_KEYS=tp-proj-dev-key-123:admin,tp-test-sandbox-456:viewer

# ═══════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════
LOG_LEVEL=INFO
