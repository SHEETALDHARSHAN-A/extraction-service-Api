# IDEP Local Environment Configuration
# Copy this file to .env and adjust values as needed

# ═══════════════════════════════════════════
# PostgreSQL Database
# ═══════════════════════════════════════════
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=idep
DATABASE_URL=postgresql://postgres:postgres@db:5432/idep

# ═══════════════════════════════════════════
# Redis Cache
# ═══════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ═══════════════════════════════════════════
# MinIO (S3-compatible Object Storage)
# ═══════════════════════════════════════════
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=idep-documents
MINIO_USE_SSL=false

# ═══════════════════════════════════════════
# Temporal Workflow Engine
# ═══════════════════════════════════════════
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=document-processing-task-queue

# ═══════════════════════════════════════════
# Triton Inference Server
# ═══════════════════════════════════════════
INFERENCE_BACKEND=triton
# triton (Docker-first, default) | glm_service (local-friendly)
TRITON_HOST=triton
TRITON_GRPC_PORT=8001
TRITON_HTTP_PORT=8000
GLM_OCR_SERVICE_URL=http://glm-ocr-service:8002

# ═══════════════════════════════════════════
# Microservices
# ═══════════════════════════════════════════
PREPROCESSING_HOST=preprocessing-service:50051
POSTPROCESSING_HOST=postprocessing-service:50052

# ═══════════════════════════════════════════
# PaddleOCR Layout Detection Service
# ═══════════════════════════════════════════
PADDLEOCR_SERVICE_URL=http://paddleocr-service:8001
PADDLEOCR_MODEL_DIR=/app/models
PADDLEOCR_USE_GPU=false
# Set to true to enable GPU mode (requires NVIDIA GPU with CUDA)
# PADDLEOCR_USE_GPU=true
MIN_CONFIDENCE_DEFAULT=0.5
MAX_IMAGE_SIZE_MB=10
PADDLEOCR_REQUEST_TIMEOUT_SECONDS=30

# ═══════════════════════════════════════════
# GLM-OCR Content Extraction Service
# ═══════════════════════════════════════════
GLM_OCR_SERVICE_URL=http://glm-ocr-service:8002
GLM_MODEL_PATH=zai-org/GLM-OCR
GLM_PRECISION_MODE=normal
# Options: normal, high, precision
GLM_DEVICE_PREFERENCE=cuda
CUDA_VISIBLE_DEVICES=0
REQUEST_TIMEOUT_SECONDS=600
LOW_VRAM_MAX_IMAGE_EDGE=1024
LOW_VRAM_RETRY_IMAGE_EDGE=768
CHUNK_TRIGGER_MAX_EDGE=1200
CHUNK_SEGMENT_COUNT=4
CHUNK_OVERLAP_PX=180
CHUNK_SEGMENT_MAX_TOKENS=1536
MAX_TOKENS_DEFAULT=2048
GLM_REQUEST_TIMEOUT_SECONDS=60

# ═══════════════════════════════════════════
# API Gateway Configuration
# ═══════════════════════════════════════════
API_PORT=8000
IDEP_API_KEYS=tp-proj-dev-key-123:admin,tp-test-sandbox-456:viewer
JWT_SECRET=idep-dev-secret-change-in-production

# Layout Detection & Orchestration
ENABLE_LAYOUT_DETECTION=true
CACHE_LAYOUT_RESULTS=true
LAYOUT_CACHE_TTL_SECONDS=3600
MAX_PARALLEL_REGIONS=5
SERVICE_TIMEOUT_SECONDS=30

# Circuit Breaker Configuration
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# ═══════════════════════════════════════════
# Logging & Monitoring
# ═══════════════════════════════════════════
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARN, ERROR

# ═══════════════════════════════════════════
# Model Caching
# ═══════════════════════════════════════════
TRANSFORMERS_CACHE=/opt/models
HF_HOME=/opt/models
