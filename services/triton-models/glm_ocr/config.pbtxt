name: "glm_ocr"
backend: "python"
max_batch_size: 4
input [
  {
    name: "images"
    data_type: TYPE_STRING
    dims: [1]
  },
  {
    name: "prompt"
    data_type: TYPE_STRING
    dims: [1]
    optional: true
  },
  {
    name: "options"
    data_type: TYPE_STRING
    dims: [1]
    optional: true
  },
  {
    name: "precision_mode"
    data_type: TYPE_STRING
    dims: [1]
    optional: true
  }
]
output [
  {
    name: "generated_text"
    data_type: TYPE_STRING
    dims: [-1]
  },
  {
    name: "confidence"
    data_type: TYPE_FP32
    dims: [1]
  }
]
instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [0]
  }
]
# Dynamic batching tuned for low-latency single requests on 0.9B model
dynamic_batching {
  preferred_batch_size: [1, 2]
  max_queue_delay_microseconds: 100000
}
# NOTE: No TensorRT accelerator — this is a Python backend model.
# GLM-OCR runs via PyTorch with bfloat16/float16 on GPU directly.
# TensorRT execution_accelerators only apply to ONNX/TensorRT backends.
parameters: {
  key: "GLM_MODEL_PATH"
  value: { string_value: "zai-org/GLM-OCR" }
}
parameters: {
  key: "precision_mode"
  value: { string_value: "normal" }
}
