name: "glm_ocr"
backend: "python"
max_batch_size: 0

# WORKAROUND: Triton Python Backend 2.42.0 has a bug where
# TYPE_STRING (BYTES) tensor data is corrupted in shared memory IPC.
# All string inputs use TYPE_UINT8 + variable dims instead.
# The model.py _first() helper decodes uint8 arrays back to strings.

input [
  {
    name: "images"
    data_type: TYPE_UINT8
    dims: [-1]
  },
  {
    name: "prompt"
    data_type: TYPE_UINT8
    dims: [-1]
    optional: true
  },
  {
    name: "options"
    data_type: TYPE_UINT8
    dims: [-1]
    optional: true
  },
  {
    name: "precision_mode"
    data_type: TYPE_UINT8
    dims: [-1]
    optional: true
  }
]
output [
  {
    name: "generated_text"
    data_type: TYPE_STRING
    dims: [-1]
  },
  {
    name: "confidence"
    data_type: TYPE_FP32
    dims: [1]
  }
]
instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [0]
  }
]
parameters: {
  key: "GLM_MODEL_PATH"
  value: { string_value: "zai-org/GLM-OCR" }
}
parameters: {
  key: "precision_mode"
  value: { string_value: "normal" }
}
