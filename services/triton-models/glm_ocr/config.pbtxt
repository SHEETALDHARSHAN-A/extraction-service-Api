name: "glm_ocr"
backend: "python"
max_batch_size: 16
input [
  {
    name: "images"
    data_type: TYPE_STRING
    dims: [1]
  },
  {
    name: "prompt"
    data_type: TYPE_STRING
    dims: [1]
    optional: true
  },
  {
    name: "options"
    data_type: TYPE_STRING
    dims: [1]
    optional: true
  },
  {
    name: "precision_mode"
    data_type: TYPE_STRING
    dims: [1]
    optional: true
  }
]
output [
  {
    name: "generated_text"
    data_type: TYPE_STRING
    dims: [-1]
  },
  {
    name: "confidence"
    data_type: TYPE_FP32
    dims: [1]
  }
]
instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [0]
  }
]
dynamic_batching {
  preferred_batch_size: [8, 16]
  max_queue_delay_microseconds: 5000
}
optimization {
  execution_accelerators {
    gpu_execution_accelerator : [ {
      name : "tensorrt"
      parameters { key: "precision_mode" value: "FP16" }
    }]
  }
}
parameters: {
  key: "GLM_MODEL_PATH"
  value: { string_value: "zai-org/GLM-OCR" }
}
parameters: {
  key: "precision_mode"
  value: { string_value: "normal" }
}
